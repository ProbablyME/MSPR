{
  "title": "RailCarbon — Train vs Avion & Santé ETL",
  "uid": "railcarbon-main",
  "schemaVersion": 38,
  "version": 4,
  "refresh": "30s",
  "time": { "from": "now-7d", "to": "now" },
  "timezone": "browser",
  "tags": ["railcarbon", "etl", "avion", "train", "co2"],

  "panels": [

    {
      "id": 100,
      "title": "Vue d'ensemble",
      "type": "row",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "panels": []
    },

    {
      "id": 1,
      "title": "Gares train",
      "type": "stat",
      "gridPos": { "x": 0, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "targets": [{ "refId": "A", "rawSql": "SELECT COUNT(*) AS val FROM mart.dim_station WHERE is_airport = FALSE;", "format": "table" }],
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "dark-green" }, "displayName": "Gares train" } }
    },

    {
      "id": 2,
      "title": "Aeroports",
      "type": "stat",
      "gridPos": { "x": 4, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "targets": [{ "refId": "A", "rawSql": "SELECT COUNT(*) AS val FROM mart.dim_station WHERE is_airport = TRUE;", "format": "table" }],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "dark-blue" }, "displayName": "Aeroports" } }
    },

    {
      "id": 3,
      "title": "Routes train",
      "type": "stat",
      "gridPos": { "x": 8, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "targets": [{ "refId": "A", "rawSql": "SELECT COUNT(*) AS val FROM mart.dim_route_train;", "format": "table" }],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "green" }, "displayName": "Routes train" } }
    },

    {
      "id": 4,
      "title": "Routes avion",
      "type": "stat",
      "gridPos": { "x": 12, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "targets": [{ "refId": "A", "rawSql": "SELECT COUNT(*) AS val FROM mart.dim_route_avion;", "format": "table" }],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" }, "displayName": "Routes avion" } }
    },

    {
      "id": 5,
      "title": "Faits emission",
      "type": "stat",
      "gridPos": { "x": 16, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "targets": [{ "refId": "A", "rawSql": "SELECT COUNT(*) AS val FROM mart.fact_emission;", "format": "table" }],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "purple" }, "displayName": "Faits" } }
    },

    {
      "id": 6,
      "title": "Runs ETL total",
      "type": "stat",
      "gridPos": { "x": 20, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "targets": [{ "refId": "A", "rawSql": "SELECT COUNT(*) AS val FROM mart.etl_run_log;", "format": "table" }],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "orange" }, "displayName": "Runs ETL" } }
    },

    {
      "id": 60,
      "title": "Routes train de jour",
      "type": "stat",
      "gridPos": { "x": 0, "y": 5, "w": 4, "h": 2 },
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "targets": [{ "refId": "A", "rawSql": "SELECT COUNT(*) AS val FROM mart.dim_route_train WHERE is_night_train = FALSE;", "format": "table" }],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "light-green" }, "displayName": "Trains de jour" } }
    },

    {
      "id": 61,
      "title": "Routes train de nuit",
      "type": "stat",
      "gridPos": { "x": 4, "y": 5, "w": 4, "h": 2 },
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "targets": [{ "refId": "A", "rawSql": "SELECT COUNT(*) AS val FROM mart.dim_route_train WHERE is_night_train = TRUE;", "format": "table" }],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "dark-purple" }, "displayName": "Trains de nuit" } }
    },

    {
      "id": 101,
      "title": "Surveillance ETL",
      "type": "row",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 },
      "panels": []
    },

    {
      "id": 10,
      "title": "Logs ETL en temps reel",
      "type": "logs",
      "gridPos": { "x": 0, "y": 6, "w": 14, "h": 7 },
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [{
        "refId": "A",
        "expr": "{application=\"railcarbon-etl\"}",
        "legendFormat": "{{level}}"
      }],
      "options": {
        "showTime": true, "showLabels": true,
        "wrapLogMessage": true, "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },

    {
      "id": 11,
      "title": "Historique des runs ETL",
      "type": "table",
      "gridPos": { "x": 14, "y": 6, "w": 10, "h": 7 },
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "targets": [{
        "refId": "A",
        "rawSql": "SELECT run_id, TO_CHAR(started_at, 'DD/MM HH24:MI') AS debut, COALESCE(ROUND(duration_s) || ' s', '...') AS duree, mois_traites AS mois, airports_charges AS airports, routes_chargees AS routes, erreurs, statut FROM mart.etl_run_log ORDER BY run_id DESC LIMIT 20;",
        "format": "table"
      }],
      "fieldConfig": {
        "overrides": [{
          "matcher": { "id": "byName", "options": "statut" },
          "properties": [
            { "id": "custom.displayMode", "value": "color-background" },
            { "id": "mappings", "value": [
              { "type": "value", "options": { "succes":   { "color": "green",  "index": 0 } } },
              { "type": "value", "options": { "erreur":   { "color": "red",    "index": 1 } } },
              { "type": "value", "options": { "en_cours": { "color": "orange", "index": 2 } } }
            ]}
          ]
        }]
      },
      "options": { "sortBy": [{ "displayName": "run_id", "desc": true }] }
    },

    {
      "id": 12,
      "title": "Erreurs & Warnings ETL",
      "type": "logs",
      "gridPos": { "x": 0, "y": 13, "w": 14, "h": 5 },
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [{
        "refId": "A",
        "expr": "{application=\"railcarbon-etl\"} |= \"ERROR\" or {application=\"railcarbon-etl\"} |= \"WARNING\"",
        "legendFormat": "{{level}}"
      }],
      "options": {
        "showTime": true, "wrapLogMessage": true, "sortOrder": "Descending",
        "showLabels": false
      }
    },

    {
      "id": 13,
      "title": "Duree des runs ETL (secondes)",
      "type": "timeseries",
      "gridPos": { "x": 14, "y": 13, "w": 10, "h": 5 },
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "targets": [{
        "refId": "A",
        "rawSql": "SELECT started_at AS \"time\", duration_s AS \"Duree (s)\", erreurs AS \"Erreurs\" FROM mart.etl_run_log WHERE started_at IS NOT NULL ORDER BY started_at;",
        "format": "time_series"
      }],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" },
        "overrides": [{
          "matcher": { "id": "byName", "options": "Erreurs" },
          "properties": [
            { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } },
            { "id": "custom.drawStyle", "value": "bars" }
          ]
        }]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },

    {
      "id": 102,
      "title": "Emissions CO2 — Comparaisons",
      "type": "row",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 18, "w": 24, "h": 1 },
      "panels": []
    },

    {
      "id": 20,
      "title": "CO2 moyen avion (kg/pax)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 19, "w": 6, "h": 4 },
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "targets": [{ "refId": "A", "rawSql": "SELECT ROUND(AVG(co2_kg_passenger)::numeric, 1) AS val FROM mart.fact_emission WHERE transport_mode = 'avion';", "format": "table" }],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "kg", "color": { "mode": "fixed", "fixedColor": "dark-blue" }, "displayName": "Avion CO2/pax" } }
    },

    {
      "id": 21,
      "title": "CO2 moyen train (kg/pax)",
      "type": "stat",
      "gridPos": { "x": 6, "y": 19, "w": 6, "h": 4 },
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "targets": [{ "refId": "A", "rawSql": "SELECT ROUND(AVG(co2_kg_passenger)::numeric, 1) AS val FROM mart.fact_emission WHERE transport_mode = 'train';", "format": "table" }],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "kg", "color": { "mode": "fixed", "fixedColor": "dark-green" }, "displayName": "Train CO2/pax" } }
    },

    {
      "id": 22,
      "title": "Routes avion avec CO2 EASA exact",
      "type": "stat",
      "gridPos": { "x": 12, "y": 19, "w": 6, "h": 4 },
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "targets": [{ "refId": "A", "rawSql": "SELECT COUNT(*) AS val FROM mart.dim_route_avion r JOIN mart.dim_vehicle_avion v ON v.icao_typecode = r.dominant_typecode;", "format": "table" }],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "green" }, "displayName": "CO2 EASA exact" } }
    },

    {
      "id": 23,
      "title": "Train vs Avion — repartition des faits",
      "type": "piechart",
      "gridPos": { "x": 18, "y": 19, "w": 6, "h": 4 },
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "targets": [{ "refId": "A", "rawSql": "SELECT transport_mode AS mode, COUNT(*) AS faits FROM mart.fact_emission GROUP BY transport_mode;", "format": "table" }],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } } },
      "options": {
        "displayLabels": ["percent", "name"],
        "legend": { "displayMode": "list", "placement": "right" }
      }
    },

    {
      "id": 30,
      "title": "Top 15 — Economies CO2 train vs avion (kg/passager)",
      "type": "barchart",
      "gridPos": { "x": 0, "y": 23, "w": 16, "h": 11 },
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "targets": [{
        "refId": "A",
        "rawSql": "SELECT COALESCE(sa.city, ra.dep_station_id) || ' -> ' || COALESCE(sb.city, ra.arr_station_id) AS route, ROUND(CAST(fa.co2_kg_passenger AS numeric), 1) AS \"Avion (kg/pax)\", ROUND(CAST(ft.co2_kg_passenger AS numeric), 1) AS \"Train (kg/pax)\", ROUND(CAST(fa.co2_kg_passenger - ft.co2_kg_passenger AS numeric), 1) AS \"Economie\" FROM mart.fact_emission fa JOIN mart.dim_route_avion ra ON ra.route_avion_id = fa.route_avion_id JOIN mart.dim_station sa ON sa.station_id = ra.dep_station_id JOIN mart.dim_station sb ON sb.station_id = ra.arr_station_id JOIN mart.dim_route_train rt ON (rt.dep_station_id IN (SELECT station_id FROM mart.dim_station WHERE city = sa.city AND is_airport = FALSE) AND rt.arr_station_id IN (SELECT station_id FROM mart.dim_station WHERE city = sb.city AND is_airport = FALSE)) JOIN mart.fact_emission ft ON ft.route_train_id = rt.route_train_id WHERE fa.transport_mode = 'avion' AND ft.transport_mode = 'train' AND fa.co2_kg_passenger > ft.co2_kg_passenger ORDER BY (fa.co2_kg_passenger - ft.co2_kg_passenger) DESC LIMIT 15;",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Avion (kg/pax)" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Train (kg/pax)" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Economie" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }]
          }
        ]
      },
      "options": {
        "xField": "route",
        "orientation": "horizontal",
        "groupWidth": 0.7,
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },

    {
      "id": 31,
      "title": "Top 10 typecodes avion dominants",
      "type": "barchart",
      "gridPos": { "x": 16, "y": 23, "w": 8, "h": 11 },
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "targets": [{
        "refId": "A",
        "rawSql": "SELECT COALESCE(r.dominant_typecode, 'Inconnu') AS typecode, COUNT(*) AS routes FROM mart.dim_route_avion r GROUP BY r.dominant_typecode ORDER BY routes DESC LIMIT 10;",
        "format": "table"
      }],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } } },
      "options": {
        "xField": "typecode", "orientation": "vertical",
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },

    {
      "id": 32,
      "title": "CO2 moyen par mode (kg/passager)",
      "type": "bargauge",
      "gridPos": { "x": 0, "y": 34, "w": 8, "h": 8 },
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "targets": [{
        "refId": "A",
        "rawSql": "SELECT transport_mode AS mode, ROUND(AVG(co2_kg_passenger)::numeric, 2) AS co2_moyen FROM mart.fact_emission GROUP BY transport_mode ORDER BY co2_moyen DESC;",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": { "unit": "kg", "color": { "mode": "palette-classic" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 50 },
            { "color": "red", "value": 150 }
          ]}
        },
        "overrides": [{ "matcher": { "id": "byName", "options": "co2_moyen" }, "properties": [{ "id": "displayName", "value": "CO2 moyen" }] }]
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },

    {
      "id": 33,
      "title": "Routes avion par categorie de service",
      "type": "piechart",
      "gridPos": { "x": 8, "y": 34, "w": 8, "h": 8 },
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "targets": [{
        "refId": "A",
        "rawSql": "SELECT COALESCE(v.service_type, 'Inconnu') AS categorie, COUNT(r.*) AS routes FROM mart.dim_route_avion r LEFT JOIN mart.dim_vehicle_avion v ON v.icao_typecode = r.dominant_typecode GROUP BY v.service_type ORDER BY routes DESC;",
        "format": "table"
      }],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } } },
      "options": {
        "displayLabels": ["percent", "name"],
        "legend": { "displayMode": "list", "placement": "right" }
      }
    },

    {
      "id": 34,
      "title": "Distribution CO2 avion par distance",
      "type": "table",
      "gridPos": { "x": 16, "y": 34, "w": 8, "h": 8 },
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "targets": [{
        "refId": "A",
        "rawSql": "SELECT CASE WHEN distance_km < 500 THEN '< 500 km' WHEN distance_km < 1000 THEN '500-1000 km' WHEN distance_km < 2000 THEN '1000-2000 km' ELSE '> 2000 km' END AS tranche, COUNT(*) AS routes, ROUND(AVG(co2_total_kg)::numeric, 0) AS co2_moy_kg FROM mart.dim_route_avion WHERE distance_km IS NOT NULL GROUP BY 1 ORDER BY MIN(distance_km);",
        "format": "table"
      }],
      "options": { "sortBy": [{ "displayName": "tranche" }] }
    },

    {
      "id": 105,
      "title": "Trains de jour vs nuit — repartition",
      "type": "row",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 42, "w": 24, "h": 1 },
      "panels": []
    },

    {
      "id": 70,
      "title": "Repartition routes : jour vs nuit",
      "type": "piechart",
      "gridPos": { "x": 0, "y": 43, "w": 6, "h": 8 },
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "targets": [{
        "refId": "A",
        "rawSql": "SELECT CASE WHEN is_night_train THEN 'Nuit' ELSE 'Jour' END AS type, COUNT(*) AS routes FROM mart.dim_route_train GROUP BY is_night_train;",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Nuit" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "dark-purple" } }] },
          { "matcher": { "id": "byName", "options": "Jour" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "light-green" } }] }
        ]
      },
      "options": {
        "displayLabels": ["percent", "name"],
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },

    {
      "id": 71,
      "title": "CO2 moyen : jour vs nuit (kg/pax)",
      "type": "bargauge",
      "gridPos": { "x": 6, "y": 43, "w": 6, "h": 8 },
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "targets": [{
        "refId": "A",
        "rawSql": "SELECT CASE WHEN rt.is_night_train THEN 'Train de nuit' ELSE 'Train de jour' END AS type, ROUND(AVG(fe.co2_kg_passenger)::numeric, 2) AS co2_moyen FROM mart.fact_emission fe JOIN mart.dim_route_train rt ON rt.route_train_id = fe.route_train_id WHERE fe.transport_mode = 'train' GROUP BY rt.is_night_train ORDER BY rt.is_night_train;",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": { "unit": "kg", "color": { "mode": "palette-classic" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        }
      },
      "options": { "orientation": "horizontal", "displayMode": "gradient", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },

    {
      "id": 72,
      "title": "Volume de routes par operateur / source",
      "type": "barchart",
      "gridPos": { "x": 12, "y": 43, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "targets": [{
        "refId": "A",
        "rawSql": "SELECT COALESCE(s.source_name, 'Inconnu') AS operateur, COUNT(rt.route_train_id) AS routes_train, COUNT(ra.route_avion_id) AS routes_avion FROM mart.dim_source s LEFT JOIN mart.dim_route_train rt ON rt.source_id = s.source_id LEFT JOIN mart.dim_route_avion ra ON ra.source_id = s.source_id GROUP BY s.source_name ORDER BY routes_train DESC LIMIT 15;",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "routes_train" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] },
          { "matcher": { "id": "byName", "options": "routes_avion" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }] }
        ]
      },
      "options": { "xField": "operateur", "orientation": "vertical", "legend": { "displayMode": "list", "placement": "bottom" } }
    },

    {
      "id": 103,
      "title": "Carte des stations & aeroports",
      "type": "row",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 51, "w": 24, "h": 1 },
      "panels": []
    },

    {
      "id": 40,
      "title": "Gares & Aeroports en Europe",
      "type": "geomap",
      "gridPos": { "x": 0, "y": 52, "w": 24, "h": 14 },
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "targets": [{
        "refId": "A",
        "rawSql": "SELECT station_name AS name, latitude, longitude, CASE WHEN is_airport THEN 1.0 ELSE 0.0 END AS is_airport_num, COALESCE(city, station_name) AS city, COALESCE(country_code, '') AS country FROM mart.dim_station WHERE latitude IS NOT NULL AND longitude IS NOT NULL AND latitude BETWEEN 35 AND 72 AND longitude BETWEEN -25 AND 45 LIMIT 8000;",
        "format": "table"
      }],
      "options": {
        "view": { "id": "coords", "lat": 48.5, "lon": 10.0, "zoom": 4 },
        "controls": { "showZoom": true, "mouseWheelZoom": true, "showScale": true },
        "basemap": { "type": "default" },
        "layers": [{
          "type": "markers",
          "name": "Stations",
          "config": {
            "size": { "fixed": 4, "min": 2, "max": 8 },
            "color": { "fixed": "green" },
            "fillOpacity": 80,
            "showLegend": true
          },
